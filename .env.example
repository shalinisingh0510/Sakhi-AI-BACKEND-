# Application Settings
SAKHI_APP_NAME=Sakhi AI API
SAKHI_APP_VERSION=0.1.0
SAKHI_ENVIRONMENT=development
SAKHI_DEBUG=false

# CORS Settings (comma-separated list of allowed origins)
SAKHI_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database Settings
SAKHI_DATABASE_PATH=sakhi_ai.sqlite3

# AI Settings
# Provider: "rule-based" (default, no API key needed) or "openai"
SAKHI_AI_PROVIDER_NAME=rule-based
SAKHI_CONVERSATION_HISTORY_LIMIT=8

# OpenAI Settings (only required when SAKHI_AI_PROVIDER_NAME=openai)
# SAKHI_OPENAI_API_KEY=sk-your-openai-api-key
# SAKHI_OPENAI_MODEL=gpt-4o-mini

# Security Settings
SAKHI_SECRET_KEY=dev-secret-change-me-in-production-use-32-byte-random-string
SAKHI_ACCESS_TOKEN_MINUTES=60
SAKHI_REFRESH_TOKEN_DAYS=7

# Rate Limiting Settings
SAKHI_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Pagination Settings
SAKHI_DEFAULT_PAGE_SIZE=20
SAKHI_MAX_PAGE_SIZE=100

# Production Settings (uncomment for production)
# SAKHI_ENVIRONMENT=production
# SAKHI_DEBUG=false
# SAKHI_CORS_ORIGINS=https://your-frontend-domain.com
# SAKHI_DATABASE_PATH=/var/lib/sakhi-ai/production.sqlite3
# SAKHI_SECRET_KEY=your-32-byte-random-secret-key
# SAKHI_RATE_LIMIT_REQUESTS_PER_MINUTE=120
# SAKHI_AI_PROVIDER_NAME=openai
# SAKHI_OPENAI_API_KEY=sk-your-openai-api-key
# SAKHI_OPENAI_MODEL=gpt-4o-mini
